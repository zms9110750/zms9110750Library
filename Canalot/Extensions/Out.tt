namespace Canalot.Extensions;

public static partial class CanalotExtensions
{
    // 单值 Out 手写
    /// <summary>
    /// 将单个值绑定到 out 变量，并返回原值
    /// </summary>
    /// <typeparam name="T">值的类型</typeparam>
    /// <param name="value">要绑定的值</param>
    /// <param name="result">绑定的变量</param>
    /// <returns>原值本身，便于链式调用</returns>
    public static T Out<T>(this T value, out T result)
    {
        result = value;
        return value;
    }

<#
    for (int i = 2; i <= 8; i++)
