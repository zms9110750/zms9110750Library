        var outNames = string.Join(", ", Enumerable.Range(1, i).Select(n => $"result{n}"));
        var typeParamDoc = string.Join("", Enumerable.Range(1, i).Select(n => $"    /// <typeparam name=\"T{n}\">第{n}个元素的类型</typeparam>\n"));
        var paramDoc = string.Join("\n", Enumerable.Range(1, i).Select(n => $"    /// <param name=\"result{n}\">第{n}个值</param>"));
        var summary = i == 2 ? "将二元组的每个元素分别绑定到对应的 out 变量，并返回原元组" : $"将{i}元组的每个元素分别绑定到对应的 out 变量，并返回原元组";
